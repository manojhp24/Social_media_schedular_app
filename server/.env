# MongoDB Database Connection URI (use local or MongoDB Atlas URI)
MONGODB_URI="mongodb://localhost:27017/scheduler"

# JWT Secret for signing authentication tokens (can be any random long string)
JWT_SECRET="YOUR_JWT_SECRET_HERE"

# API keys for AI Services (Zernio & Gemini)
ZERNIO_API_KEY="YOUR_ZERNIO_API_KEY_HERE"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# API key for Leonardo AI Image Generator (if used)
LEONARDO_API_KEY="YOUR_LEONARDO_API_KEY_HERE"

# Cloudinary configuration details for image/media uploads
CLOUDINARY_CLOUD_NAME="YOUR_CLOUDINARY_CLOUD_NAME_HERE"
CLOUDINARY_API_KEY="YOUR_CLOUDINARY_API_KEY_HERE"
CLOUDINARY_API_SECRET="YOUR_CLOUDINARY_API_SECRET_HERE"
